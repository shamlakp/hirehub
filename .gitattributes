# Standardize line endings to LF for all text files
* text=auto

# Source code files (Force LF)
*.dart text eol=lf
*.py text eol=lf
*.js text eol=lf
*.html text eol=lf
*.css text eol=lf
*.md text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Config files
.env* text eol=lf
.gitignore text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
